# 複製此檔案為 .env 並根據需要調整設定

# JWT 設定（必填，啟動時無預設值會報錯）
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# 以下為安全相關設定（皆有預設值，可視需要覆蓋）

# HSTS 設定
SECURITY_ENABLE_HSTS=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# CSP 設定
SECURITY_ENABLE_CSP=true
SECURITY_CSP_REPORT_ONLY=false
SECURITY_CSP_REPORT_URI=/api/csp-report

# 其他安全設定
SECURITY_ENABLE_HEADERS=true
SECURITY_HIDE_SERVER=true
SECURITY_SERVER_HEADER=FastAPI

# 開發模式 (會使用較寬鬆的 CSP)
SECURITY_DEVELOPMENT_MODE=false
# 應用程式設定
# DEBUG 預設為 false（安全預設）；開發環境設 true 以啟用詳細錯誤與 API docs
DEBUG=true

# MongoDB 連線（預設值不帶憑證；含帳密的連線字串務必放在 .env，不要寫進程式碼）
MONGODB_URL=mongodb://root:password@localhost:27017

# Redis 連線
REDIS_URL=redis://localhost:6379/0

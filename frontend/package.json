{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --diagnostic-sources \"js,svelte\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --diagnostic-sources \"js,svelte\" --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"check:naming": "node scripts/check-naming-conflicts.js",
		"check:all": "npm run check && npm run lint && npm run check:naming"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.67.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"daisyui": "^5.5.23",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"glob": "^13.0.6",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.0",
		"svelte-eslint-parser": "^1.8.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	},
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"axios": "^1.18.1",
		"date-fns": "^4.4.0",
		"nanoid": "^5.1.15"
	}
}
